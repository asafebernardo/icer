{
  "name": "Material",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string",
      "description": "T\u00edtulo do material"
    },
    "descricao": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o do material"
    },
    "tipo": {
      "type": "string",
      "enum": ["pdf", "audio", "video", "imagem", "documento", "apresentacao"],
      "description": "Tipo do material"
    },
    "categoria": {
      "type": "string",
      "enum": [
        "liturgia",
        "louvor",
        "estudo",
        "infantil",
        "administrativo",
        "divulgacao"
      ],
      "description": "Categoria do material"
    },
    "arquivo_url": {
      "type": "string",
      "description": "URL do arquivo"
    },
    "imagem_url": {
      "type": "string",
      "description": "URL da imagem de capa"
    }
  },
  "required": ["titulo"]
}
