{
  "name": "Material",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string",
      "description": "T\u00edtulo do material"
    },
    "descricao": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o do material"
    },
    "tipo": {
      "type": "string",
      "enum": ["pdf", "audio", "video", "imagem", "documento", "apresentacao"],
      "description": "Tipo do material"
    },
    "categoria": {
      "type": "string",
      "description": "Identificador da categoria (ex.: sem_categoria, ou id personalizado)"
    },
    "icone_id": {
      "type": ["string", "null"],
      "description": "Id do \u00edcone Lucide opcional para o cart\u00e3o"
    },
    "arquivo_url": {
      "type": "string",
      "description": "URL do arquivo"
    },
    "imagem_url": {
      "type": "string",
      "description": "URL da imagem de capa"
    }
  },
  "required": ["titulo"]
}
