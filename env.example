# --- Frontend (Vite) ---
# Copie para `.env` ou `.env.local`. Prefixo VITE_ é exposto ao browser.

# Ativa login real contra o servidor Node (`server/index.js`) e cookies httpOnly.
# Valores aceites (igual ao proxy Vite): true | 1 | yes | on
VITE_USE_SERVER_AUTH=true

# URL de uma API upstream (opcional) quando NÃO usa apenas o Node.
# Em dev com VITE_USE_SERVER_AUTH=true, o Vite proxy de `/api` vai para o Node local.
# VITE_APP_BASE_URL=https://your-upstream.example.com

# Demo local (inseguro em produção)
# VITE_ENABLE_DEMO_LOGIN=true
# VITE_DEMO_ADMIN_EMAIL=admin@example.com
# VITE_DEMO_ADMIN_PASSWORD=

# Upload de imagens só no browser (data URL)
# VITE_LOCAL_IMAGE_UPLOAD=true

# --- Servidor Node (`npm run dev:server` / systemd) ---
# MongoDB — escolha UM dos modos (local OU Atlas).
MONGODB_DB_NAME=icer
#
# --- Modo local (MongoDB na máquina, porta 27017) ---
MONGODB_URI=mongodb://127.0.0.1:27017
#
# --- Modo Atlas (Opção A — recomendado): comente ou apague MONGODB_URI acima e use: ---
# MONGODB_SRV_HOST=cluster0.xxxxx.mongodb.net
# MONGODB_USER=...   ou   MONGODB_SRV_USER=...
# MONGODB_PASSWORD=...   ou   MONGODB_SRV_PASSWORD=...
# MONGODB_DB_NAME=icer   ou   MONGODB_SRV_DATABASE=icer
# (O código monta mongodb+srv://… com encoding correto.)
# Não use MONGODB_URI=$VAR — o Node/dotenv não expande $ como no shell.

# Ficheiros de media (imagens, PDF, vídeo) no disco do servidor — só metadados no MongoDB
# Em produção: use um caminho ABSOLUTO fora da pasta que o deploy substitui (ex.: /var/lib/icer/uploads),
# para cópias/rsync não apagarem os ficheiros. Ver DEPLOY.md.
# ICER_UPLOAD_DIR=server/uploads
# ICER_UPLOAD_MAX_MB=80
# ICER_FILE_PUBLIC_READ=true

# Porta interna (reverse proxy aponta /api para aqui)
PORT=3001
# ICER_SERVER_PORT=3001
#
# Em Docker/EasyPanel: com `PORT` definido, o servidor escuta em 0.0.0.0 (acessível de fora).
# Para forçar manualmente: HOST=0.0.0.0 ou HOST=127.0.0.1
# HOST=

# Cookie de sessão (opcional; padrão em auth.js)
# ICER_SESSION_COOKIE_NAME=icer_session
# ICER_SESSION_SECRET=...   # se usar assinatura no futuro

# Uma sessão ativa por conta (predefinido: ativo). `false` permite vários dispositivos sem bloqueio.
# Na UI de login também existe «encerrar outra sessão» com a mesma palavra-passe.
# ICER_ENFORCE_SINGLE_SESSION=false

# Seed de contas para login no site (só cria se o e-mail ainda não existir na base)
# Palavra-passe: mín. 12 caracteres com maiúscula, minúscula, número e símbolo (igual à API).
ICER_ADMIN_EMAIL=admin@example.com
ICER_ADMIN_FULL_NAME=Administrador
# Mín. 12 caracteres: maiúscula, minúscula, número e símbolo (ver política no servidor).
ICER_ADMIN_PASSWORD=Change-me-Min12!

# Segunda conta de administrador (opcional; só cria se o e-mail ainda não existir)
ICER_USER_EMAIL=user@example.com
ICER_USER_FULL_NAME=Outro administrador
ICER_USER_PASSWORD=Change-me-Min12!

# --- Google Drive OAuth (backup) ---
# Base pública do site (usada para montar o Redirect URI do OAuth, atrás de proxy).
# Em produção, coloque o domínio final.
# ICER_PUBLIC_BASE_URL=https://seu-dominio.com
#
# Chave para cifrar tokens OAuth guardados no MongoDB (app_kv).
# Recomendado: um valor longo e aleatório. (O servidor deriva uma chave AES-256.)
# ICER_GOOGLE_OAUTH_ENC_KEY=coloque-uma-chave-forte-aqui

# Encaminhar outras rotas /api/* para API externa, exceto auth/admin/users/files/health
# ICER_UPSTREAM_API=https://your-upstream.example.com
