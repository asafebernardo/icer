# ── Login de demonstração (local apenas) ─────────────────────────────
# Nunca use palavra-passe fraca em produção. Sem estas variáveis, o formulário
# de login em /login não aceita credenciais (comportamento seguro por omissão).
# Exemplo: admin@icer.com.br + nome em VITE_DEMO_ADMIN_FULL_NAME
VITE_ENABLE_DEMO_LOGIN=false
VITE_DEMO_ADMIN_FULL_NAME=
VITE_DEMO_ADMIN_EMAIL=
VITE_DEMO_ADMIN_PASSWORD=

# ── Integridade da sessão no browser (opcional) ───────────────────────
# Se definir um segredo longo e aleatório, o objeto `user` em localStorage
# é guardado assinado; edições manuais invalidam a sessão.
# Gere com: openssl rand -hex 32
# VITE_CLIENT_SESSION_SECRET=
