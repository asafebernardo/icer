# --- Frontend (Vite) ---
# Copie para `.env` ou `.env.local`. Prefixo VITE_ é exposto ao browser.

# Ativa login real contra o servidor Node (`server/index.js`) e cookies httpOnly.
VITE_USE_SERVER_AUTH=true

# URL da API legada (Base44 / upstream) quando NÃO usa apenas o Node.
# Em dev com VITE_USE_SERVER_AUTH=true, o Vite proxy de `/api` vai para o Node local.
# VITE_APP_BASE_URL=https://your-base44-app.example.com

# Demo local (inseguro em produção)
# VITE_ENABLE_DEMO_LOGIN=true
# VITE_DEMO_ADMIN_EMAIL=admin@example.com
# VITE_DEMO_ADMIN_PASSWORD=

# Upload de imagens só no browser (data URL)
# VITE_LOCAL_IMAGE_UPLOAD=true

# --- Servidor Node (`npm run dev:server` / systemd) ---
# MongoDB (obrigatório para a API)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=icer

# Porta interna (reverse proxy aponta /api para aqui)
PORT=3001
# ICER_SERVER_PORT=3001

# Cookie de sessão (opcional; padrão em auth.js)
# ICER_SESSION_COOKIE_NAME=icer_session
# ICER_SESSION_SECRET=...   # se usar assinatura no futuro

# Seed do primeiro admin (só cria se ainda não existir utilizador)
ICER_ADMIN_EMAIL=admin@example.com
ICER_ADMIN_FULL_NAME=Administrador
ICER_ADMIN_PASSWORD=change-me-min-10-chars

# Encaminhar outras rotas /api/* para API externa (Base44), exceto auth/admin/users/files/health
# ICER_UPSTREAM_API=https://your-upstream.example.com
