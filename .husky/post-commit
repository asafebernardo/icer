#!/usr/bin/env sh
# Atualiza CHANGELOG.md a partir dos commits (Conventional Commits) e junta ao commit que acabou de ser feito.
if git rev-parse HEAD^2 >/dev/null 2>&1; then
  # Commit de merge: não fazer amend.
  exit 0
fi
npm run changelog --silent 2>/dev/null || true
if ! git rev-parse --verify HEAD >/dev/null 2>&1; then
  exit 0
fi
git add CHANGELOG.md 2>/dev/null || true
if git diff --cached --quiet 2>/dev/null; then
  exit 0
fi
GIT_EDITOR=true git commit --amend --no-edit --no-verify
